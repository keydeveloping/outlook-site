# Outlook Web Inbox - Environment Configuration
# Copy this file to .env and fill in your values

# ── Encryption ──────────────────────────────────────────────
# IMPORTANT: Generate encryption key before running the app
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ENCRYPTION_KEY=your_encryption_key_here

# Salt for key derivation (optional, change to any string)
ENCRYPTION_SALT=outlook-web-inbox-salt-2024

# ── Admin Credentials ───────────────────────────────────────
ADMIN_USER=admin
# Can be plain text or encrypted: ENC:encrypted_value
ADMIN_PASS=change_me_to_strong_password

# ── Flask Settings ──────────────────────────────────────────
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
# Can be plain text or encrypted: ENC:encrypted_value
FLASK_SECRET_KEY=change_me_to_random_string
FLASK_DEBUG=false

# ── Session Settings ────────────────────────────────────────
# Session lifetime in hours
SESSION_LIFETIME_HOURS=4

# ── Rate Limiting ───────────────────────────────────────────
# Enable rate limiting on login (true/false)
RATE_LIMIT_ENABLED=true

# Max failed attempts before lockout
RATE_LIMIT_MAX_ATTEMPTS=5

# Lockout duration in minutes
RATE_LIMIT_LOCKOUT_MINUTES=15

# Sliding window for counting attempts in minutes
RATE_LIMIT_SLIDING_WINDOW_MINUTES=5

# ── File Upload ─────────────────────────────────────────────
# Max upload file size in MB
MAX_UPLOAD_SIZE_MB=10
